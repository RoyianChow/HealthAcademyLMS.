generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  stripeCustomerId String? @unique

  role       String?
  banned     Boolean?
  banReason  String?
  banExpires DateTime?

  sessions    Session[]
  accounts    Account[]
  courses     Course[]
  enrollments Enrollment[]

  // NEW:
  // Tracks overall course completion per user.
  // Use this if you want to show "Course completed" or award certificates.
  courseProgress CourseProgress[]

  quizAttempts QuizAttempt[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Course {
  id String @id @default(uuid())

  title            String
  description      String
  smallDescription String
  slug             String @unique
  category         String

  price    Int
  duration Int
  level    CourseLevel  @default(Beginner)
  status   CourseStatus @default(Draft)

  fileKey String

  // NEW:
  // Optional separate course thumbnail/image key.
  // Use this if you want a dedicated course cover image instead of reusing fileKey.
  thumbnailKey String?

  stripePriceId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chapters    Chapter[]
  quizzes     Quiz[]
  enrollments Enrollment[]

  // NEW:
  // Lets you see progress/completion at the course level.
  courseProgress CourseProgress[]

  @@index([userId])
  @@index([status])
}

model Chapter {
  id String @id @default(uuid())

  title    String
  position Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  lessons Lesson[]
  quizzes Quiz[]

  @@unique([courseId, position])
  @@index([courseId])
}

model Lesson {
  id String @id @default(uuid())

  title       String
  description String?

  content String?

  thumbnailKey String?
  videoKey     String?
  youtubeUrl   String?

  position      Int
  isPublished   Boolean @default(false)
  isFreePreview Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  lessonProgress Boolean          @default(false)
  documents      LessonDocument[]

  @@unique([chapterId, position])
  @@index([chapterId])
}

model LessonDocument {
  id String @id @default(uuid())

  name     String
  fileKey  String
  fileUrl  String?
  fileType String?
  fileSize Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Enrollment {
  id String @id @default(uuid())

  amount Int
  status EnrollmentStatus @default(Pending)

  // NEW:
  // Store the Stripe Checkout Session ID here.
  // Very useful for webhook matching and debugging purchases.
  stripeSessionId String?

  // NEW:
  // Store the payment intent/payment ID if you want payment-level tracing.
  // Helpful for refunds, disputes, and admin support.
  stripePaymentId String?

  // NEW:
  // When the purchase was actually completed.
  // Good for receipts, dashboards, and access history.
  purchasedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId String
  userId   String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([status])
  @@index([courseId])
  @@index([userId])
}

model CourseProgress {
  id String @id @default(uuid())

  // NEW TABLE:
  // Stores a user's overall completion state for a course.
  // This is useful if you do not want to recalculate completion every time from lessons.
  completed Boolean @default(false)

  // NEW:
  // Timestamp for when the course was fully completed.
  // Good for certificates, transcripts, and completion history.
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Quiz {
  id String @id @default(uuid())

  title       String
  description String?
  isPublished Boolean @default(false)

  passingScore          Int?
  timeLimitMinutes      Int?
  allowMultipleAttempts Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // ✅ NEW: connect quiz to chapter (optional)
  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([chapterId])
}

model QuizQuestion {
  id String @id @default(uuid())

  question    String
  position    Int
  explanation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  options QuizOption[]
  answers QuizAnswer[]

  @@unique([quizId, position])
  @@index([quizId])
}

model QuizOption {
  id String @id @default(uuid())

  text      String
  isCorrect Boolean @default(false)
  position  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answers QuizAnswer[] @relation("SelectedOptionAnswers")

  @@unique([questionId, position])
  @@index([questionId])
}

model QuizAttempt {
  id String @id @default(cuid())

  quizId String
  userId String

  // NEW:
  // Which try this is for the same user on the same quiz.
  // Example: 1 = first attempt, 2 = second attempt.
  attemptNumber Int @default(1)

  isComplete Boolean @default(false)

  // NEW:
  // Marks whether teacher/admin has finished grading this submission.
  // Useful for admin dashboards and "pending grading" filters.
  isGraded Boolean @default(false)

  score Int?

  // NEW:
  // Teacher/admin written feedback for this attempt.
  // Example: "Good work, but review question 3."
  feedback String?

  submittedAt DateTime?
  gradedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers QuizAnswer[]

  // NEW:
  // Ensures one row per attempt number for the same user and quiz.
  // So the same user can have attempt 1, attempt 2, attempt 3, etc.
  @@unique([quizId, userId, attemptNumber])
  @@index([quizId])
  @@index([userId])
  @@index([isComplete])
  @@index([isGraded])
}

model QuizAnswer {
  id String @id @default(cuid())

  attemptId        String
  questionId       String
  selectedOptionId String?

  isCorrect Boolean?
  createdAt DateTime @default(now())

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Uses a named relation because QuizOption already relates to QuizQuestion,
  // so Prisma needs help knowing this relation is specifically for selected answers.
  selectedOption QuizOption? @relation("SelectedOptionAnswers", fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([selectedOptionId])
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
}

enum CourseStatus {
  Draft
  Published
  Archived
}

enum EnrollmentStatus {
  Pending
  Active
  Cancelled
}
